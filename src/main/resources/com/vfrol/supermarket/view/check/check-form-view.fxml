<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import org.controlsfx.control.SearchableComboBox?>
<VBox fx:id="formPanel" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.check.CheckFormController"
      prefWidth="750" prefHeight="650" spacing="15"
      style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;">

    <Label fx:id="titleLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="15" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
            <ColumnConstraints minWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Check Number:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="checkNumberField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Customer Card:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <SearchableComboBox fx:id="customerCardComboBox" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250"/>

        <CheckBox fx:id="useDiscount" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
    </GridPane>

    <Separator/>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Items in Check" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Remove Selected" onAction="#onRemoveSale"/>
        <Button text="+ Add Item" onAction="#onAddSale" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="salesTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="upcColumn" text="UPC" prefWidth="120"/>
            <TableColumn fx:id="nameColumn" text="Product Name" prefWidth="200"/>
            <TableColumn fx:id="priceColumn" text="Price"/>
            <TableColumn fx:id="quantityColumn" text="Qty" prefWidth="60"/>
            <TableColumn fx:id="totalColumn" text="Total" prefWidth="90"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="20">
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="VAT (20%):" style="-fx-font-weight: bold;"/>
            <Label fx:id="vatLabel" text="0.00"/>
        </HBox>
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Total Sum:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Label fx:id="sumTotalLabel" text="0.00" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #4CAF50;"/>
        </HBox>
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Cancel" onAction="#onCancel"/>
        <Button fx:id="saveButton" text="Save" onAction="#onSave" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="detailsPanel" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.check.CheckDetailsController"
      prefWidth="700" prefHeight="600" spacing="15"
      style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">

    <Label text="Check Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="20" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS"/>
            <ColumnConstraints minWidth="120" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Check Number:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="checkNumberLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Date &amp; Time:" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight: bold;"/>
        <Label fx:id="dateLabel" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Cashier:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="cashierLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Customer:" GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-font-weight: bold;"/>
        <Label fx:id="customerLabel" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Sum Total:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="sumTotalLabel" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-font-size: 14px; -fx-text-fill: #2e7d32;"/>

        <Label text="VAT (20%):" GridPane.rowIndex="2" GridPane.columnIndex="2" style="-fx-font-weight: bold;"/>
        <Label fx:id="vatLabel" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
    </GridPane>

    <Separator/>

    <Label text="Purchased Items" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

    <TableView fx:id="salesTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="upcColumn" text="UPC" prefWidth="120"/>
            <TableColumn fx:id="productColumn" text="Product Name" prefWidth="200"/>
            <TableColumn fx:id="quantityColumn" text="Qty" prefWidth="60"/>
            <TableColumn fx:id="priceColumn" text="Unit Price" prefWidth="100"/>
            <TableColumn fx:id="totalColumn" text="Total" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="deleteButton" text="Delete Check" onAction="#onDelete" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="Close" onAction="#hide"/>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="formPanel" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.employee.EmployeeFormController"
      maxWidth="450" maxHeight="600" spacing="15"
      style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;">

    <Label text="Edit Employee" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="idField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="New Password:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="passwordField" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Enter password to confirm update"/>

        <Label text="Surname:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="surnameField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Name:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="nameField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Patronymic:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="patronymicField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Role:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="roleComboBox" GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="200"/>

        <Label text="Salary:" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="salaryField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Date of Birth:" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="dobPicker" GridPane.rowIndex="7" GridPane.columnIndex="1" prefWidth="200"/>

        <Label text="Date of Start:" GridPane.rowIndex="8" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="dosPicker" GridPane.rowIndex="8" GridPane.columnIndex="1" prefWidth="200"/>

        <Label text="Phone:" GridPane.rowIndex="9" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

        <Label text="City:" GridPane.rowIndex="10" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="cityField" GridPane.rowIndex="10" GridPane.columnIndex="1"/>

        <Label text="Street:" GridPane.rowIndex="11" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="streetField" GridPane.rowIndex="11" GridPane.columnIndex="1"/>

        <Label text="Zip Code:" GridPane.rowIndex="12" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="zipField" GridPane.rowIndex="12" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Cancel" onAction="#onCancel"/>
        <Button text="Save" onAction="#onSave" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.SearchableComboBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.store_product.StoreProductListController"
      spacing="10"
      prefHeight="600.0" prefWidth="900.0">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Enter product UPC to search" prefWidth="400"/>
        <Button text="Filters" onAction="#onToggleFilterClick"/>
        <Button fx:id="addButton" text="Add Store Product" onAction="#onAddStoreProductClick"/>
        <Button text="Export to Excel" onAction="#onExportClick" style="-fx-background-color: #217346; -fx-text-fill: white;"/>
    </HBox>

    <VBox fx:id="filterPanel" spacing="10" visible="false" managed="false"
          style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 10;">
        <HBox spacing="15" alignment="CENTER_LEFT">

            <Label text="Product:"/>
            <SearchableComboBox fx:id="productFilterComboBox" prefWidth="200" promptText="Type to search..."/>

            <Label text="Promotional:"/>
            <ComboBox fx:id="promotionalFilterComboBox" prefWidth="100"/>

            <Label text="Sort by:"/>
            <ComboBox fx:id="sortByComboBox" prefWidth="150"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Clear" onAction="#onClearFilterClick"/>
            <Button text="Apply" onAction="#applyFilter" defaultButton="true"/>
        </HBox>
    </VBox>

    <TableView fx:id="storeProductTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="upcColumn"         text="UPC"/>
            <TableColumn fx:id="nameColumn"        text="Product Name"/>
            <TableColumn fx:id="priceColumn"       text="Price"/>
            <TableColumn fx:id="quantityColumn"    text="Quantity"/>
            <TableColumn fx:id="promotionalColumn" text="Promotional"/>
        </columns>
    </TableView>

</VBox>
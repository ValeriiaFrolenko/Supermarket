<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="detailsPanel" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.store_product.StoreProductDetailsController"
      maxWidth="400" maxHeight="400" spacing="15"
      style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">

    <Label text="Store Product Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="UPC:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="upcLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="UPC Promo:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="upcPromLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Product:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="productNameLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Category:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="categoryNameLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Price:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="priceLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Quantity:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="quantityLabel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Promotional:" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="promotionalLabel" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="deleteButton" text="Delete" onAction="#onDelete" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button fx:id="editButton" text="Edit" onAction="#onEdit" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Close" onAction="#hide"/>
    </HBox>
</VBox>

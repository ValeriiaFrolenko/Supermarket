<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import org.controlsfx.control.SearchableComboBox?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.analytics.SalesAnalyticsController"
      spacing="10" prefHeight="700.0" prefWidth="1100.0">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Sales Analytics"
           style="-fx-font-size: 20; -fx-font-weight: bold;"/>

    <HBox spacing="20" alignment="CENTER_LEFT">
        <VBox spacing="4"
              style="-fx-background-color: #e8f5e9; -fx-padding: 12;
                     -fx-border-radius: 6; -fx-background-radius: 6; -fx-min-width: 220;">
            <Label text="Total Sales Amount" style="-fx-text-fill: #555;"/>
            <Label fx:id="totalAmountLabel" text="—"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
        </VBox>
        <VBox spacing="4"
              style="-fx-background-color: #e3f2fd; -fx-padding: 12;
                     -fx-border-radius: 6; -fx-background-radius: 6; -fx-min-width: 220;">
            <Label text="Total Quantity Sold" style="-fx-text-fill: #555;"/>
            <Label fx:id="totalQuantityLabel" text="—"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
        </VBox>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Quick range:" style="-fx-font-weight: bold;"/>
        <Button text="Last 7 days"  onAction="#onLast7DaysClick"/>
        <Button text="Last 30 days" onAction="#onLast30DaysClick"/>
        <Button text="This month"   onAction="#onThisMonthClick"/>
        <Button text="This year"    onAction="#onThisYearClick"/>
    </HBox>

    <VBox fx:id="filterPanel" spacing="10" visible="false" managed="false"
          style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 10;">

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Date from:"/>
            <DatePicker fx:id="dateFromPicker" prefWidth="130"/>

            <Label text="to:"/>
            <DatePicker fx:id="dateToPicker" prefWidth="130"/>

            <Label text="Product:"/>
            <SearchableComboBox fx:id="productComboBox" prefWidth="200" editable="true"
                                promptText="All products"/>

            <Label text="Cashier:"/>
            <SearchableComboBox fx:id="cashierComboBox" prefWidth="200" editable="true"
                      promptText="All cashiers"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Sort by:"/>
            <ComboBox fx:id="sortByComboBox" prefWidth="180" promptText="Default (date desc)"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Clear Filters" onAction="#onClearFilterClick"/>
            <Button text="Apply"         onAction="#applyFilter" defaultButton="true"/>
        </HBox>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Filters"         onAction="#onToggleFilterClick"/>
        <Button text="Export to Excel" onAction="#onExportClick"
                style="-fx-background-color: #217346; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="analyticsTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="productNameColumn"  text="Product"              prefWidth="200"/>
            <TableColumn fx:id="quantitySoldColumn" text="Qty Sold"             prefWidth="80"/>
            <TableColumn fx:id="totalAmountColumn"  text="Total Amount (UAH)"   prefWidth="150"/>
            <TableColumn fx:id="checkNumberColumn"  text="Receipt #"            prefWidth="110"/>
            <TableColumn fx:id="cashierNameColumn"  text="Cashier"              prefWidth="160"/>
            <TableColumn fx:id="dateTimeColumn"     text="Date &amp; Time"      prefWidth="140"/>
        </columns>
        <placeholder>
            <Label text="Apply a filter or use a date shortcut to load data."/>
        </placeholder>
    </TableView>

</VBox>

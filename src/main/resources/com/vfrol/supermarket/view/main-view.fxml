<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.vfrol.supermarket.controller.MainController"
            prefHeight="600.0" prefWidth="900.0">

    <left>
        <VBox fx:id="sideBar" spacing="8"
              style="-fx-background-color: #f4f4f4; -fx-padding: 15;"
              visible="false" managed="false">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>

            <Button fx:id="accountButton" text="Account" onAction="#goToAccount" prefWidth="180"/>
            <Button fx:id="employeesButton" text="Employees" onAction="#goToEmployees" prefWidth="180"/>
            <Button fx:id="categoriesButton" text="Categories" onAction="#goToCategories" prefWidth="180"/>
            <Button fx:id="productsButton" text="Products" onAction="#goToProducts" prefWidth="180"/>
            <Button fx:id="storeProductsButton" text="Store Products" onAction="#goToStoreProducts" prefWidth="180"/>
            <Button fx:id="checksButton" text="Checks" onAction="#goToChecks" prefWidth="180"/>
            <Button fx:id="customersButton" text="Customers" onAction="#goToCustomers" prefWidth="180"/>
            <Separator/>
            <Button fx:id="salesAnalyticsButton"
                    text="Sales Analytics"
                    onAction="#goToSalesAnalytics"
                    prefWidth="180"/>
            <Button fx:id="employeePerformanceButton"
                    text="Employee Performance"
                    onAction="#goToEmployeePerformance"
                    prefWidth="180"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <VBox fx:id="centerMenu" spacing="8" alignment="CENTER">
                <Button text="Account" onAction="#goToAccount" prefWidth="180"/>
                <Button text="Employees" onAction="#goToEmployees" prefWidth="180"/>
                <Button text="Categories" onAction="#goToCategories" prefWidth="180"/>
                <Button text="Products" onAction="#goToProducts" prefWidth="180"/>
                <Button text="Store Products" onAction="#goToStoreProducts" prefWidth="180"/>
                <Button text="Checks" onAction="#goToChecks" prefWidth="180"/>
                <Button text="Customers" onAction="#goToCustomers" prefWidth="180"/>
                <Button fx:id="salesAnalyticsCenterButton"
                        text="Sales Analytics"
                        onAction="#goToSalesAnalytics"
                        prefWidth="180"/>
                <Button fx:id="employeePerformanceCenterButton"
                        text="Employee Performance"
                        onAction="#goToEmployeePerformance"
                        prefWidth="180"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>

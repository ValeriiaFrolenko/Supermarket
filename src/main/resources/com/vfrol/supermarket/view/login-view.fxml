<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.LoginController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #f0f0f0; -fx-padding: 40;"
      fillWidth="false">

    <Label text="Supermarket Management System" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10" maxWidth="350">
        <columnConstraints>
            <ColumnConstraints minWidth="100"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="idField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="passwordField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-font-weight: bold;"/>

    <Button text="Login" onAction="#onLogin" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-padding: 10 20;"/>

</VBox>
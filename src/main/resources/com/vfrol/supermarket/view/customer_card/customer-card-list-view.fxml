<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.customer_card.CustomerCardListController"
      spacing="10"
      prefHeight="600.0" prefWidth="800.0">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Enter surname to search" prefWidth="400"/>
        <Button text="Filters" onAction="#onToggleFilterClick"/>
        <Button fx:id="addButton" text="Add Customer Card" onAction="#onAddCustomerCardClick"/>
        <Button text="Export to Excel" onAction="#onExportClick" style="-fx-background-color: #217346; -fx-text-fill: white;"/>
    </HBox>

    <VBox fx:id="filterPanel" spacing="10" visible="false" managed="false"
          style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 10;">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Phone:"/>
            <TextField fx:id="phoneFilterField" promptText="Phone number"/>

            <Label text="Discount from:"/>
            <TextField fx:id="discountFromField" promptText="0" prefWidth="60"/>

            <Label text="to:"/>
            <TextField fx:id="discountToField" promptText="100" prefWidth="60"/>

            <Label text="Sort by:"/>
            <ComboBox fx:id="sortByComboBox" prefWidth="130"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Clear" onAction="#onClearFilterClick"/>
            <Button text="Apply" onAction="#applyFilter" defaultButton="true"/>
        </HBox>
    </VBox>

    <TableView fx:id="customerCardTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="cardNumberColumn" text="Card Number"/>
            <TableColumn fx:id="surnameColumn" text="Surname"/>
            <TableColumn fx:id="nameColumn" text="Name"/>
            <TableColumn fx:id="phoneColumn" text="Phone"/>
            <TableColumn fx:id="discountColumn" text="Discount (%)"/>
        </columns>
    </TableView>

</VBox>
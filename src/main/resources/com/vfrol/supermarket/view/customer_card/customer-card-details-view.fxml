<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="detailsPanel" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.customer_card.CustomerCardDetailsController"
      maxWidth="400" maxHeight="420" spacing="15"
      style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">

    <Label text="Customer Card Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Card Number:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="cardNumberLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Surname:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="surnameLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Name:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="nameLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Patronymic:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="patronymicLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Phone:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="phoneLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="City:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="cityLabel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Street:" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="streetLabel" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Zip Code:" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="zipLabel" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

        <Label text="Discount:" GridPane.rowIndex="8" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="discountLabel" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="deleteButton" text="Delete" onAction="#onDelete" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="Edit" onAction="#onEdit" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Close" onAction="#hide"/>
    </HBox>
</VBox>

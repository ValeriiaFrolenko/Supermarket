<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="formPanel" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vfrol.supermarket.controller.customer_card.CustomerCardFormController"
      maxWidth="450" maxHeight="550" spacing="15"
      style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5;">

    <Label fx:id="label" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Card Number:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="cardNumberField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Surname:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="surnameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Name:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="nameField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Patronymic:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="patronymicField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Phone:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="City:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="cityField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Street:" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="streetField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Zip Code:" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="zipField" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

        <Label text="Discount (%):" GridPane.rowIndex="8" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextField fx:id="discountField" GridPane.rowIndex="8" GridPane.columnIndex="1" promptText="0-100"/>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Cancel" onAction="#onCancel"/>
        <Button text="Save" onAction="#onSave" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
    </HBox>
</VBox>
